  "keyFeatures": [
    "Redux Toolkit state management with localStorage persistence",
    "Advanced filtering, sorting, and search functionality",
    "Automatic bulk discount calculation (10% off for 3+ items)",
    "Custom pizza creation with React Hook Form and Zod validation",
    "Analytics dashboard with Recharts visualizations",
    "Responsive design with Tailwind CSS and Framer Motion animations"
  ],
  "publicApiSurface": [
    "pizzaSlice.setSearch(search: string)",
    "pizzaSlice.setCategory(category: string)",
    "pizzaSlice.setMaxPrice(price: number)",
    "pizzaSlice.setSortBy(sortBy: SortOption)",
    "pizzaSlice.addPizzaToCatalog(pizza: Pizza)",
    "orderSlice.addToOrder({ pizza: Pizza, quantity: number })",
    "orderSlice.removeFromOrder(pizzaId: string)",
    "orderSlice.updateQuantity({ pizzaId: string, quantity: number })",
    "orderSlice.clearOrder()",
    "orderSlice.addOrderToHistory(order: Order)"
  ]
